# JARVIS v2.0 .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local

# Logs (keep directory, ignore log files)
logs/*.log
logs/access.log
logs/error.log

# Memory / ChromaDB (runtime data)
memory/chroma_db/
memory/data/*.db

# Journal entries (personal)
journal/

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Node (for some tools)
node_modules/

# Testing
.pytest_cache/
.coverage
htmlcov/
