# ============================================================
# AKSHAY AI CORE — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# =========================
# SYSTEM CONFIGURATION
# =========================
APP_NAME=AKSHAY_AI_CORE
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Unique system identifier (auto-generated on first run if empty)
SYSTEM_ID=

# =========================
# SECURITY CONFIGURATION
# =========================
# Master encryption key (32 bytes, base64 encoded)
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MASTER_ENCRYPTION_KEY=

# JWT settings for API authentication
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Session settings
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Face authentication settings
FACE_AUTH_ENABLED=true
FACE_AUTH_CONFIDENCE_THRESHOLD=0.85
FACE_AUTH_MAX_REGISTRATION_IMAGES=10

# PIN authentication
PIN_ENABLED=true
PIN_MIN_LENGTH=6
PIN_MAX_LENGTH=12

# Voice lock command (emergency lock phrase)
VOICE_LOCK_PHRASE=LOCK SYSTEM
VOICE_LOCK_ENABLED=true

# =========================
# AI MODEL CONFIGURATION
# =========================
# Primary AI provider: openai, anthropic, google, ollama
PRIMARY_AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4096

# Google (Gemini) Configuration
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro
GOOGLE_MAX_TOKENS=4096

# Ollama (Local) Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_KEEP_ALIVE=5m

# =========================
# MEMORY SYSTEM
# =========================
# Vector database for semantic memory
VECTOR_DB_TYPE=chromadb
VECTOR_DB_PATH=./data/vector_db
VECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Memory settings
MEMORY_SHORT_TERM_LIMIT=100
MEMORY_COMPRESSION_INTERVAL_DAYS=7
MEMORY_MAX_CONTEXT_TOKENS=8000

# =========================
# DATABASE CONFIGURATION
# =========================
# SQLite (default, encrypted)
DATABASE_URL=sqlite+aiosqlite:///./data/akshay_core.db
DATABASE_ENCRYPTION_ENABLED=true

# Redis (optional, for caching and queues)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =========================
# API CONFIGURATION
# =========================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# CORS settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

# WebSocket settings
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# =========================
# PLUGIN CONFIGURATION
# =========================
PLUGINS_ENABLED=true
PLUGINS_DIR=./plugins
PLUGINS_SANDBOX_ENABLED=true
PLUGINS_MAX_EXECUTION_TIME=300

# Built-in plugins to enable
PLUGIN_WEB_AUTOMATION=true
PLUGIN_SYSTEM_CONTROL=true
PLUGIN_ESP32_IOT=true
PLUGIN_FILE_VAULT=true
PLUGIN_CYBER_TOOLS=true
PLUGIN_DATA_ANALYSIS=true

# =========================
# AUTOMATION CONFIGURATION
# =========================
AUTOMATION_ENABLED=true
AUTOMATION_MAX_CONCURRENT_JOBS=10
AUTOMATION_JOB_TIMEOUT_SECONDS=3600
AUTOMATION_RULES_FILE=./config/automation_rules.yaml

# =========================
# LOGGING CONFIGURATION
# =========================
LOG_DIR=./logs
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
AUDIT_LOG_IMMUTABLE=true

# =========================
# UI CONFIGURATION
# =========================
# Web UI
WEB_UI_ENABLED=true
WEB_UI_PORT=3000

# Desktop app settings
DESKTOP_START_MINIMIZED=false
DESKTOP_SYSTEM_TRAY=true

# Voice interface
VOICE_INTERFACE_ENABLED=true
VOICE_WAKE_WORD=hey akshay
VOICE_TTS_ENABLED=true
VOICE_TTS_VOICE=en-US-Neural2-J

# =========================
# EXTERNAL SERVICES
# =========================
# ESP32 IoT Hub
ESP32_HUB_HOST=
ESP32_HUB_PORT=1883
ESP32_HUB_USERNAME=
ESP32_HUB_PASSWORD=

# Notification services
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# =========================
# DEVELOPMENT SETTINGS
# =========================
DEV_BYPASS_AUTH=false
DEV_MOCK_AI_RESPONSES=false
DEV_VERBOSE_LOGGING=false
