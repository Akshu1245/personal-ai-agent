# JARVIS v2.0 — Environment Configuration
# Copy this to .env and fill in your values
# In Replit: add these as Secrets (not .env)

# ── Required ──────────────────────────────
# Get a free API key from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Optional AI Settings ──────────────────
GROQ_MODEL=llama-3.3-70b-versatile
# Options: llama-3.3-70b-versatile | llama-3.1-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768

# ── App Config ────────────────────────────
# Change this to a long random string in production
SECRET_KEY=change_this_to_a_long_random_string

# ── Features ──────────────────────────────
VOICE_ENABLED=false       # Set true only on local desktop with speakers
DEBUG=false               # Never set true in production

# ── User Identity ─────────────────────────
USER_NAME=Akshay
