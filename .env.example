# JARVIS Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# API KEYS
# ============================================

# Groq API Key (Required) - Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq Model (default: llama-3.3-70b-versatile)
# Options: llama-3.3-70b-versatile, llama-3.1-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (Optional - for fallback)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# ============================================
# VOICE SETTINGS
# ============================================

# Enable voice input/output
VOICE_ENABLED=true

# Enable wake word detection
WAKE_WORD_ENABLED=true

# Wake word
WAKE_WORD=hey jarvis

# TTS Engine (pyttsx3 or coqui)
TTS_ENGINE=pyttsx3

# Speech rate (words per minute)
TTS_RATE=150

# TTS Volume (0.0 to 1.0)
TTS_VOLUME=1.0

# Whisper model (tiny, base, small, medium, large)
WHISPER_MODEL=base

# ============================================
# BROWSER SETTINGS
# ============================================

# Default browser (chrome, firefox, edge)
DEFAULT_BROWSER=chrome

# Run browser in headless mode
HEADLESS_BROWSER=false

# ============================================
# SYSTEM SETTINGS
# ============================================

# Debug mode
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Require authentication
REQUIRE_AUTH=false

# ============================================
# PRODUCTIVITY SETTINGS
# ============================================

# Daily briefing time (HH:MM)
DAILY_BRIEFING_TIME=09:00

# Focus mode duration in minutes
FOCUS_DURATION=30

# Crypto alert price for Cardano (ADA) in INR
ADA_ALERT_PRICE=50

# ============================================
# SECURITY
# ============================================

# Secret key for sessions
SECRET_KEY=change-this-to-a-random-string
